// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PosterElementType {
  IMAGE
  TEXT
}

model Template {
  id              String                 @id @default(cuid())
  name            String                 @unique
  canvasWidth     Int
  canvasHeight    Int
  backgroundImage String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  elements        TemplateElement[]
}

model TemplateElement {
  id          String             @id @default(cuid())
  templateId  String
  type        PosterElementType

  // 画布几何
  x          Int
  y          Int
  width      Int
  height     Int
  zIndex     Int

  // 变量键：用于生成页向该元素填充值（模板内唯一）
  variableKey String

  // IMAGE 默认值（可为空；生成时可由用户提供 URL/上传结果覆盖）
  src        String?

  // TEXT 默认值
  defaultText String?
  fontSize    Int?
  color       String?
  fontFamily  String?
  textAlign   String?
  verticalAlign String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, variableKey])
  @@index([templateId])
}

model Font {
  id        String   @id @default(cuid())
  name      String   @unique
  fileName  String
  url       String
  format    String   // ttf / woff / woff2 / otf
  createdAt DateTime @default(now())
}
